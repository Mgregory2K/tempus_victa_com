{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Holodeck Session",
  "type": "object",
  "properties": {
    "session_id": { "type": "string" },
    "start_timestamp_utc": { "type": "string", "format": "date-time" },
    "end_timestamp_utc": { "type": "string", "format": "date-time" },
    "topic": { "type": "string" },
    "moderator": { "type": "string" },
    "mode": { "type": "string" },
    "round_limit": { "type": "integer" },
    "participants": {
      "type": "array",
      "items": { "type": "string" }
    },
    "transcript": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp_utc": { "type": "string", "format": "date-time" },
          "sender": { "type": "string" },
          "sender_type": { "type": "string", "enum": ["user", "moderator", "participant"] },
          "content": { "type": "string" },
          "round": { "type": "integer" }
        },
        "required": ["timestamp_utc", "sender", "sender_type", "content"]
      }
    },
    "summary": { "type": "string" },
    "notable_quotes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "speaker": { "type": "string" },
          "text": { "type": "string" },
          "context": { "type": "string" }
        },
        "required": ["speaker", "text"]
      }
    },
    "metadata": { "type": "object" }
  },
  "required": ["session_id", "start_timestamp_utc", "topic", "moderator", "mode", "participants", "transcript"]
}
