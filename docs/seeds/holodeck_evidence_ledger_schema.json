{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Holodeck Evidence Ledger",
  "type": "object",
  "properties": {
    "entity_id": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["book", "speech", "interview", "letter", "historical_archive", "biography", "debate", "public_writing", "academic_reference"] },
          "title": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "relevance": { "type": "string" },
          "confidence_weight": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["type", "title", "confidence_weight"]
      }
    },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "discarded_claims": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["entity_id", "evidence"]
}
